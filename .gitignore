*.hex
*.retry

/roles/i3/files/config.d/*.local.conf

# ZDOTDIR is set to ~/.config/zsh, which is symlinked to config/zsh
# These files are created by zsh in ZDOTDIR but should not be tracked by git
/config/zsh/.zcompcache/
/config/zsh/.zcompdump*
/config/zsh/.zsh_history
/config/zsh/.zsh_sessions/

# Local overrides for jsonnet configs (machine-specific, may contain secrets)
*.local.jsonnet

# Machine role (private or work). Managed via `dot role set`.
/.role

# Build artifacts
/config/claude/settings.json
/config/claude/mcp-servers.json
/config/claude/.settings.json.installed
