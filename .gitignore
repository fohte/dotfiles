*.hex
*.retry

/roles/i3/files/config.d/*.local.conf

# ZDOTDIR is set to ~/.config/zsh, which is symlinked to config/zsh
# These files are created by zsh in ZDOTDIR but should not be tracked by git
/config/zsh/.zcompcache/
/config/zsh/.zcompdump*
/config/zsh/.zsh_history
/config/zsh/.zsh_sessions/
# Role overlays deployed into ZDOTDIR by `dot deploy`.
/config/zsh/.zshenv.overlay
/config/zsh/.zshrc.overlay

# Role overlays deployed by `dot deploy`. runok and tmux dirs are symlinked
# wholesale into ~/.config, so their overlay files materialize inside this
# repo. armyknife symlinks individual files instead (see symlinks), but its
# work.yaml still lands here if ~/.config/armyknife is a directory symlink
# left over from an older deploy.
/config/runok/work.yml
/config/armyknife/work.yaml
/config/tmux/tmux.conf.overlay

# Local overrides for jsonnet configs (machine-specific, may contain secrets)
*.local.jsonnet

# Machine role (private or work). Managed via `dot role set`.
/.role

# Build artifacts
/config/claude/settings.json
/config/claude/mcp-servers.json
/config/claude/.settings.json.installed
/config/launchd/*.plist

# ~/.claude/skills is a dir-symlink to /config/claude/skills, so per-skill
# symlinks created by work overlay SessionStart hooks materialize here.
# Ignore those (git treats symlinks as files) and only track real base skill
# directories.
/config/claude/skills/*
!/config/claude/skills/*/
