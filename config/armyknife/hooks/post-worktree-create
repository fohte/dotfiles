#!/bin/bash
# post-worktree-create hook for armyknife.
# Called by `a wm new` after creating a git worktree.
#
# armyknife discovers this file at $XDG_CONFIG_HOME/armyknife/hooks/post-worktree-create
# (defaults to ~/.config/armyknife/hooks/post-worktree-create).
# See: https://github.com/fohte/armyknife/blob/main/src/shared/hooks.rs
#
# Environment variables set by armyknife:
#   ARMYKNIFE_WORKTREE_PATH - absolute path to the newly created worktree
#   ARMYKNIFE_BRANCH_NAME   - branch name associated with the worktree
#   ARMYKNIFE_REPO_ROOT     - root path of the original git repository
#
# Hook errors are non-fatal; armyknife logs a warning and continues.
set -euo pipefail

if [[ -z "${ARMYKNIFE_WORKTREE_PATH:-}" ]]; then
  exit 0
fi

# Run bootstrap script if present (e.g. mise install, dependency install).
# --worktree skips lefthook install since worktrees share the parent's .git/hooks.
bootstrap="$ARMYKNIFE_WORKTREE_PATH/scripts/bootstrap"
if [[ -x "$bootstrap" ]]; then
  "$bootstrap" --worktree
fi

# Create .marksman.toml in new worktrees so that marksman LSP can detect the project root.
# In worktrees, .git is a file (not a directory), which marksman's Directory.Exists() check
# doesn't recognize. .marksman.toml serves as an alternative root marker.
if [ ! -f "$ARMYKNIFE_WORKTREE_PATH/.marksman.toml" ]; then
  touch "$ARMYKNIFE_WORKTREE_PATH/.marksman.toml"
fi

# Copy git-ignored .env files from the original repo root to the new worktree.
# Tracked .env files are already present via git worktree, so only ignored ones
# (containing local secrets, overrides, etc.) need to be copied explicitly.
if [[ -n "${ARMYKNIFE_REPO_ROOT:-}" ]]; then
  for f in "$ARMYKNIFE_REPO_ROOT"/.env*; do
    [[ -f "$f" ]] || continue
    basename="$(basename "$f")"
    # Skip if the file is tracked by git (not ignored)
    if git -C "$ARMYKNIFE_REPO_ROOT" check-ignore -q "$f" 2> /dev/null; then
      cp "$f" "$ARMYKNIFE_WORKTREE_PATH/$basename"
    fi
  done
fi

# Register the worktree as a trusted project in Claude Code (~/.claude.json).
# Without this, Claude Code prompts for trust confirmation on every new worktree.
# Only trust worktrees under the user's own repositories.
CLAUDE_JSON="$HOME/.claude.json"
if [[ "$ARMYKNIFE_WORKTREE_PATH" == "$HOME/ghq/github.com/fohte/"* ]] &&
  [[ -f "$CLAUDE_JSON" ]]; then
  jq --arg path "$ARMYKNIFE_WORKTREE_PATH" \
    '.projects[$path].hasTrustDialogAccepted = true' \
    "$CLAUDE_JSON" > "$CLAUDE_JSON.tmp" && mv "$CLAUDE_JSON.tmp" "$CLAUDE_JSON"
fi
