#!/bin/bash
#
# Pass `runok audit --json` output through, dropping entries that are no longer
# `ask` under the current ruleset or that match an IGNORE_COMMANDS regex.
# Designed to be consumed by the `runok-review-asks` Claude skill.
#
# Output: the original `runok audit --json` JSONL, unmodified, with non-matching
# entries omitted. The script does not reshape, dedupe, or aggregate — that is
# the LLM's job.

set -euo pipefail

# Extended regular expressions matched against the top-level `.command` field.
# Matching entries are never proposed for allow-listing.
IGNORE_COMMANDS=(
  '^a wm new'
  # Claude Code drives Renovate PR approve -> merge, but a blanket allow
  # is too broad (any PR, not just vetted Renovate ones), so keep ask.
  '^gh (-R [^ ]+ |--repo [^ ]+ )?pr review .* --approve'
  '^gh (-R [^ ]+ |--repo [^ ]+ )?pr merge'
  # Direct pushes to a master-push-repos entry (no PR safety net) should
  # always be confirmed, including from a `.worktrees/` checkout.
  '^git( -C [^ ]+)? push$'
  '^git( -C [^ ]+)? push origin (main|master)$'
  '^git( -C [^ ]+)? push -u origin HEAD$'
)

ignore_regex=$(printf '|%s' "${IGNORE_COMMANDS[@]}")
ignore_regex=${ignore_regex:1}

# Default --action ask unless the caller specified one.
has_action=0
for a in "$@"; do
  case "$a" in
    --action | --action=*) has_action=1 ;;
  esac
done

audit_args=()
if [[ $has_action -eq 0 ]]; then
  audit_args+=(--action ask)
fi
audit_args+=("$@")

runok audit --json "${audit_args[@]}" |
  jq -c --arg ignore "$ignore_regex" 'select((.command | test($ignore)) | not)' |
  while IFS= read -r line; do
    cmd=$(jq -r '.command' <<< "$line")
    # `runok check` evaluates each stdin line as a separate command, so a
    # heredoc-bearing compound yields multiple JSON docs. Treat the entry as
    # still-ask if ANY sub-decision is ask (otherwise long heredoc compounds
    # whose middle subcommands hit ask get silently dropped).
    # On any parse error, fall back to ask so the entry surfaces for review.
    decision=$(printf '%s\n' "$cmd" | runok check --output-format json 2> /dev/null | jq -sr '[.[].decision] | if any(. == "ask") then "ask" else "other" end' 2> /dev/null || echo ask)
    if [[ "$decision" == "ask" ]]; then
      printf '%s\n' "$line"
    fi
  done
