#!/bin/bash
#
# Pass `runok audit --json` output through, dropping entries that are no longer
# `ask` under the current ruleset or that match an IGNORE_COMMANDS regex.
# Designed to be consumed by the `runok-review-asks` Claude skill.
#
# Output: the original `runok audit --json` JSONL, unmodified, with non-matching
# entries omitted. The script does not reshape, dedupe, or aggregate — that is
# the LLM's job.

set -euo pipefail

# Extended regular expressions matched against the top-level `.command` field.
# Matching entries are never proposed for allow-listing.
IGNORE_COMMANDS=(
  '^a wm new'
  '^gh (-R [^ ]+ |--repo [^ ]+ )?pr review .* --approve'
)

ignore_regex=$(printf '|%s' "${IGNORE_COMMANDS[@]}")
ignore_regex=${ignore_regex:1}

# Default --action ask unless the caller specified one.
has_action=0
for a in "$@"; do
  case "$a" in
    --action | --action=*) has_action=1 ;;
  esac
done

audit_args=()
if [[ $has_action -eq 0 ]]; then
  audit_args+=(--action ask)
fi
audit_args+=("$@")

runok audit --json "${audit_args[@]}" |
  jq -c --arg ignore "$ignore_regex" 'select((.command | test($ignore)) | not)' |
  while IFS= read -r line; do
    cmd=$(jq -r '.command' <<< "$line")
    # On parse error in `runok check`, treat the entry as still-ask so it
    # surfaces for manual review instead of being silently dropped.
    decision=$(printf '%s\n' "$cmd" | runok check --output-format json 2> /dev/null | jq -r '.decision // "ask"' 2> /dev/null || echo ask)
    if [[ "$decision" == "ask" ]]; then
      printf '%s\n' "$line"
    fi
  done
