#!/usr/bin/env bash
#
# tmux-session-fzf - Interactive tmux session switcher with fzf preview
#
# Requirements:
#   - tmux
#   - fzf
#   - ghq (for listing repositories)
#   - tmux-window-info (for window information display)
#
# Usage:
#   tmux-session-fzf
#     - Shows help message
#
#   tmux-session-fzf switch
#     - Shows a list of existing tmux sessions and available ghq repositories
#     - 🔋 prefix: existing sessions (sorted by last used, excluding current session)
#     - 🔌 prefix: new sessions from ghq repositories (not yet created)
#     - 🗑️: kill session option
#     - Preview shows windows and active pane contents with powerline-style headers
#
#   tmux-session-fzf kill
#     - Shows a list of tmux sessions to kill
#     - Supports multi-selection
#
#   tmux-session-fzf preview <session-name>
#     - Internal command used by fzf for preview generation
#     - Shows session windows with powerline-style headers and pane contents
#
set -euo pipefail

# Add mise shims to PATH for tools like ghq and fzf
MISE_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/mise"
if [ -d "$MISE_DATA_DIR/shims" ]; then
  export PATH="$MISE_DATA_DIR/shims:$PATH"
fi

if [ -z "$TMUX" ]; then
  echo "This command must be run in tmux" >&2
  exit 1
fi

EXISTING_PREFIX='🔋'
NEW_PREFIX='🔌'
KILL_PREFIX='🗑️'

#
# Helper functions
#

show_help() {
  cat << 'EOF'
tmux-session-fzf - Interactive tmux session switcher

Usage:
  tmux-session-fzf switch    Switch to a tmux session (with fzf preview)
  tmux-session-fzf kill      Kill tmux sessions (with multi-selection)

Options:
  -h, --help                 Show this help message
EOF
}

# Extract session name by removing any known prefix
# Usage: extract_session_name <text>
extract_session_name() {
  local text="$1"
  # Remove any prefix
  text="${text#"$EXISTING_PREFIX"}"
  text="${text#"$NEW_PREFIX"}"
  text="${text#"$KILL_PREFIX"}"
  # Remove leading space if any
  text="${text# }"
  echo "$text"
}

# Common fzf wrapper with consistent UI settings
# Usage: run_fzf_selector <input> [additional-fzf-options...]
run_fzf_selector() {
  local input="$1"
  shift

  # Invoked from `display-popup -E` (tmux.conf M-s binding), so fzf takes
  # over the popup's tty directly — no `--tmux` flag needed. This avoids the
  # fzf-tmux proxy double-launch (proxy.go fifo + sh + second fzf process).
  echo "$input" | fzf \
    --preview "$0 preview {}" \
    --preview-window 'right:70%' \
    "$@" || true
}

#
# Preview mode functions (internal use by fzf)
#

run_preview_mode() {
  selected="${1:-}"

  # No preview for kill session option
  if [[ "$selected" == "$KILL_PREFIX"* ]]; then
    exit 0
  fi

  # Preview README.md for new sessions
  if [[ "$selected" == "$NEW_PREFIX"* ]]; then
    repo_name="$(extract_session_name "$selected")"
    readme_path="$(ghq root)/github.com/$repo_name/README.md"

    if [ -f "$readme_path" ]; then
      bat --style=plain --color=always "$readme_path"
    else
      echo "No README.md found for $repo_name"
    fi
    exit 0
  fi

  # Preview existing session
  session_name="$(extract_session_name "$selected")"

  if ! tmux has-session -t "$session_name" 2> /dev/null; then
    exit 0
  fi

  # \033[1;34m = bold blue, \033[0m = reset
  echo -e "\033[1;34m━━━ $session_name ━━━\033[0m"
  echo ""

  tmux list-windows -t "$session_name" -F "#{window_index}|#{window_id}|#{window_active}" |
    while IFS='|' read -r win_index win_id win_active; do
      active_pane=$(tmux list-panes -t "$session_name:$win_index" -F "#{pane_index}|#{pane_current_command}|#{pane_active}" | grep '|1$' | cut -d'|' -f1,2)
      pane_index=$(echo "$active_pane" | cut -d'|' -f1)

      win_info=$(tmux-name info "$win_id")

      header_text="$win_index  $win_info"
      padding_length=$((120 - ${#header_text} - 10))
      padding=$(printf '%*s' $padding_length '')

      # Powerline-style header with color segments
      # Format: \033[48;5;N;Mm = background color N, foreground color M
      # Colors: 28=dark green, 238=gray, 240=light gray, 237=darker gray, 97=bright white
      #  = powerline separator character
      if [ "$win_active" = "1" ]; then
        # Active window: [dark green bg + white text] [separator] [light gray bg] [separator] [darker gray bg]
        echo -e "\033[48;5;28;97m $win_index \033[48;5;240;38;5;28m\033[48;5;240;97m $win_info \033[48;5;237;38;5;240m\033[48;5;237m$padding\033[0m"
      else
        # Inactive window: [gray bg + white text] [separator] [light gray bg] [separator] [darker gray bg]
        echo -e "\033[48;5;238;97m $win_index \033[48;5;240;38;5;238m\033[48;5;240;97m $win_info \033[48;5;237;38;5;240m\033[48;5;237m$padding\033[0m"
      fi
      echo ""

      tmux capture-pane -t "$session_name:$win_index.$pane_index" -e -p | tail -15

      echo ""
    done
  exit 0
}

#
# Switch mode functions
#

# Each `tmux` invocation from a non-client process opens a fresh socket
# (~75ms on macOS) which dominates startup latency. The caller is expected to
# pass session data pre-expanded via tmux format strings so this function does
# zero tmux IPC. `ghq list` runs in parallel with the (trivial) parsing.
#
# Args:
#   $1: current session name (skips `tmux display-message`)
#   $2: raw session list, formatted as "<last_attached>|<name>;<last_attached>|<name>;..."
#       (produced by tmux format `#{S:#{session_last_attached}|#{session_name};}`)
print_list() {
  local current_session="${1:-$(tmux display-message -p '#S')}"
  local raw_sessions="${2:-}"
  if [ -z "$raw_sessions" ]; then
    raw_sessions="$(tmux list-sessions -F "#{session_last_attached}|#{session_name};" | tr -d '\n')"
  fi

  local ghq_out
  ghq_out="$(mktemp)"
  ghq list > "$ghq_out" &
  local ghq_pid=$!

  # "ts|name;ts|name;" → "ts name\nts name\n..."
  local all_sessions
  all_sessions="$(echo "$raw_sessions" | tr ';' '\n' | tr '|' ' ' | grep -v '^[[:space:]]*$')"

  echo "$all_sessions" |
    sort -rn |
    cut -d' ' -f2- |
    grep -vFx "$current_session" |
    sed "s/^/$EXISTING_PREFIX/"

  wait "$ghq_pid"

  # session names use '_' instead of '.' (see tmux-name session)
  cut -d/ -f2-3 "$ghq_out" |
    grep -vFxf <(echo "$all_sessions" | cut -d' ' -f2- | tr '_' '.') |
    sed "s/^/$NEW_PREFIX/"
  rm -f "$ghq_out"

  echo "$KILL_PREFIX kill session"
}

run_switch_mode() {
  fzf_result="$(run_fzf_selector "$(print_list "${1:-}" "${2:-}")" --print-query)"
  selected="$(echo "$fzf_result" | sed -n 2p)"

  # if no selection, do nothing
  if [ -z "$selected" ]; then
    return
  fi

  case "$selected" in
    "$NEW_PREFIX"*)
      repo_name="$(extract_session_name "$selected")"
      dir="$(ghq root)/github.com/$repo_name"
      session_name="$(tmux-name session "$dir")"
      tmux new-session -s "$session_name" -d -c "$dir"
      tmux switch -t "$session_name"
      # create a second window
      tmux new-window -t "$session_name" -c "$dir"
      ;;

    "$EXISTING_PREFIX"*)
      session_name="$(extract_session_name "$selected")"
      tmux switch -t "$session_name"
      ;;

    "$KILL_PREFIX"*)
      run_kill_mode
      ;;
  esac
}

#
# Kill mode functions
#

run_kill_mode() {
  session_list="$(tmux list-sessions | cut -d: -f1)"
  selected="$(run_fzf_selector "$session_list" --multi)"

  if [ -n "$selected" ]; then
    echo "$selected" | xargs -I% tmux kill-session -t %
  fi
}

#
# Main logic
#

# Show help if no arguments
if [ $# -eq 0 ]; then
  show_help
  exit 0
fi

MODE="${1:-}"
shift || true

# Handle different modes
case "$MODE" in
  preview)
    run_preview_mode "$@"
    ;;
  switch)
    run_switch_mode "$@"
    ;;
  kill)
    run_kill_mode
    ;;
  -h | --help)
    show_help
    exit 0
    ;;
  *)
    echo "Error: Unknown mode: $MODE" >&2
    echo "" >&2
    show_help
    exit 1
    ;;
esac
