# --- role overlay ---
# `brew bundle` sanitizes PATH, so invoke `dot` by absolute path.
# realpath resolves the ~/.config/homebrew/Brewfile symlink to the dotfiles
# repo; __dir__ would not, so do not let rubocop fold this into __dir__.
brewfile_real = File.realpath(__FILE__)
dotfiles_dir = File.expand_path('../../..', brewfile_real)
overlay = `#{dotfiles_dir}/config/bin/dot role overlay config/homebrew/Brewfile`.strip
instance_eval(File.read(overlay), overlay) if !overlay.empty? && File.exist?(overlay)
