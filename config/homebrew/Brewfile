# frozen_string_literal: true

# Homebrew bundle manifest.
#
# Apply:        brew bundle
# Detect drift: brew bundle cleanup             (installed but not declared; no --force = list only)
# Check:        brew bundle check --verbose     (declared but not installed)
#
# Only top-level leaves are tracked; transitive deps are pulled in automatically.
# Third-party tap entries use fully qualified names so explicit `tap` lines are
# unnecessary (brew bundle auto-taps when it sees `user/tap/name`).

# ===== Common =====

# Network Kanji code conversion Filter (NKF)
brew 'nkf'
# GNU File, Shell, and Text utilities
brew 'coreutils'
# Collection of GNU find, xargs, and locate
brew 'findutils'
# GNU implementation of the famous stream editor
brew 'gnu-sed'
# GNU version of the tar archiving utility
brew 'gnu-tar'
# GNU implementation of time utility
brew 'gnu-time'
# GNU grep, egrep and fgrep
brew 'grep'
# Collection of tools that nobody wrote when UNIX was young
brew 'moreutils'
# Executes a program periodically, showing output fullscreen
brew 'watch'

# ===== File search & monitoring =====

# Simple, fast and user-friendly alternative to find
brew 'fd'
# Monitor a directory for changes and run a shell command
brew 'fswatch'
# Watch files and take action when they change
brew 'watchman'

