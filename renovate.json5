{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>fohte/renovate-config:base.json5',
    'github>aquaproj/aqua-renovate-config#2.2.1',
  ],
  packageRules: [
    {
      schedule: [
        'after 9am on saturday',
      ],
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      automerge: true,
      matchPackageNames: [
        '/^aquaproj//',
      ],
    },
  ],
}
